<robot name="bordered_plate_model">
    <contact name="top">
        <link name="plate_base_link"/>
        <point>
             0.500 -0.500 0.03
             0.500  0.500 0.03
            -0.500  0.500 0.03
            -0.500 -0.500 0.03
        </point>
        <shape> 4 0 1 2 3 </shape>
    </contact>
    <contact name="bottom">
        <link name="plate_base_link"/>
        <point>
             0.500 -0.500 -0.0
             0.500  0.500 -0.0
            -0.500  0.500 -0.0
            -0.500 -0.500 -0.0
        </point>
        <shape> 4 3 2 1 0 </shape>
    </contact>
</robot>

<CycloneDDS>
    <Domain>
        <General>
            <AllowMulticast>true</AllowMulticast>
            <MaxMessageSize>1400B</MaxMessageSize>
            <Interfaces>
                <NetworkInterface name="docker0" priority="default" multicast="default" />
            </Interfaces>
        </General>

        <Discovery>
            <ParticipantIndex>auto</ParticipantIndex>
            <MaxAutoParticipantIndex>500</MaxAutoParticipantIndex>
        </Discovery>

        <Internal>
            <Watermarks>
                <WhcHigh>2000kB</WhcHigh>
            </Watermarks>
        </Internal>

        <Tracing>
            <Verbosity>config</Verbosity>
            <OutputFile>${HOME}/.ros/log/cdds.log</OutputFile>
        </Tracing>
    </Domain>
</CycloneDDS>

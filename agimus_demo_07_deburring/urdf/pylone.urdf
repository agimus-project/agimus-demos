<?xml version="1.0" ?>
<robot name="pylone">
   <material name="grey">
        <color rgba=".5 .5 .5 1" />
    </material>

   <link name="pylone_link">
      <visual>
         <geometry>
            <mesh filename="package://agimus_demo_07_deburring/urdf/meshes/pylone.stl" scale="1.0 1.0 1.0"/>
         </geometry>
         <material name="grey">
            <color rgba="0.0 0.9 0.9 1.0"/>
         </material>
      </visual>
      <collision>
         <geometry>
            <mesh filename="package://agimus_demo_07_deburring/urdf/meshes/pylone.stl" scale="1.0 1.0 1.0"/>
         </geometry>
      </collision>
      <inertial>
         <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
         <mass value="0.1"/>
         <inertia ixx="1" ixy="0" ixz="0" iyy="1" iyz="0" izz="1"/>
      </inertial>
   </link>
</robot>

<robot name="bordered_plate_model">
    <contact name="top">
        <link name="plate_base_link"/>
        <point>
             0.500 -0.500 0.015
             0.500  0.500 0.015  
            -0.500  0.500 0.015  
            -0.500 -0.500 0.015  
        </point>
        <shape> 4 0 1 2 3 </shape>
    </contact>
    <contact name="bottom">
        <link name="plate_base_link"/>
        <point>
             0.500 -0.500 -0.015  
             0.500  0.500 -0.015  
            -0.500  0.500 -0.015  
            -0.500 -0.500 -0.015  
        </point>
        <shape> 4 3 2 1 0 </shape>
    </contact>
</robot>

<?xml version='1.0' encoding='utf-8'?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:macro name="support" params="">
    <link name="support_link">
      <inertial>
        <mass value="200" />
        <origin xyz="0 0 0.45" />
        <inertia ixx="50" ixy="0" ixz="0" iyy="50" iyz="0" izz="50" />
      </inertial>
      <visual>
        <origin xyz="0 0 0.38" />
        <geometry>
          <box size="1.703 1.803 0.76" />
        </geometry>
        <material name="blue">
          <color rgba="0 0.3 0.9 1.0" />
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0.38" />
        <geometry>
          <box size="1.703 1.803 0.76" />
        </geometry>
      </collision>
      <!--visual>
          <origin xyz="-0.61 0.2215 0.77"/>
          <geometry>
	    <box size="0.363 0.252 0.02"/>
          </geometry>
        </visual>
        <collision>
          <origin xyz="-0.61 0.2215 0.77"/>
          <geometry>
	    <box size="0.363 0.252 0.02"/>
          </geometry>
        </collision-->
      <!-- <visual>
        <origin xyz="0.6385 -0.1655 0.77" />
        <geometry>
          <box size="0.3 0.3 0.02" />
        </geometry>
        <material name="blue" />
      </visual>
      <collision>
        <origin xyz="0.6385 -0.1655 0.77" />
        <geometry>
          <box size="0.3 0.3 0.02" />
        </geometry>
      </collision> -->
    </link>

    <link name="wall_link_1">
      <inertial>
        <mass value="200" />
        <origin xyz="0 0 1." />
        <inertia ixx="50" ixy="0" ixz="0" iyy="50" iyz="0" izz="50" />
      </inertial>
      <visual>
        <origin xyz="0 0 1.0" />
        <geometry>
          <box size="3.0 0.1 2.0" />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 1.0" />
        <geometry>
          <box size="3.0 0.1 2.0" />
        </geometry>
      </collision>
    </link>
    <link name="wall_link_2">
      <inertial>
        <mass value="200" />
        <origin xyz="0 0 1." />
        <inertia ixx="50" ixy="0" ixz="0" iyy="50" iyz="0" izz="50" />
      </inertial>
      <visual>
        <origin xyz="0 0 1.0" />
        <geometry>
          <box size="0.1 2.0 2.0" />
        </geometry>
        <material name="lightGrey">
          <color rgba="0.9 0.9 0.9 0.5" />
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 1.0" />
        <geometry>
          <box size="0.1 2.0 2.0" />
        </geometry>
      </collision>
    </link>
    <link name="wall_link_3">
      <inertial>
        <mass value="200" />
        <origin xyz="0 0 1." />
        <inertia ixx="50" ixy="0" ixz="0" iyy="50" iyz="0" izz="50" />
      </inertial>
      <visual>
        <origin xyz="0 0 1.0" />
        <geometry>
          <box size="0.7 0.12 2.0" />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 1.0" />
        <geometry>
          <box size="0.7 0.12 2.0" />
        </geometry>
      </collision>
    </link>
    <link name="pedestal">
      <inertial>
        <mass value="1." />
        <origin xyz="1.05 0.45 0.4625" />
        <inertia ixx=".01" iyy=".01" izz=".1" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <visual>
        <origin xyz="0 0 0.4625" />
        <geometry>
          <box size="0.25 0.25 0.925" />
        </geometry>
        <material name="blue">
          <color rgba="0 0.3 0.9 1.0" />
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0.4625" />
        <geometry>
          <box size="0.25 0.25 0.925" />
        </geometry>
      </collision>
    </link>
    <link name="foam_block">
      <inertial>
        <mass value="1." />
        <origin xyz="1.05 0.45 0.4625" />
        <inertia ixx=".01" iyy=".01" izz=".1" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <visual>
        <origin xyz="0 0 0.0225" />
        <geometry>
          <box size="0.2 0.4 0.045" />
        </geometry>
        <material name="transp_blue">
          <color rgba="0 0.3 0.9 0.5" />
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0.0225" />
        <geometry>
          <box size="0.2 0.4 0.045" />
        </geometry>
      </collision>
    </link>

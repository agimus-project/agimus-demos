    </link> -->
    <!-- <link name="obj_pedestal2">
      <inertial>
        <mass value="1." />
        <origin xyz="1.05 0.45 0.4625" />
        <inertia ixx=".01" iyy=".01" izz=".1" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <visual>
        <origin xyz="0 0 0.02" />
        <geometry>
          <box size="0.05 0.05 0.03" />
        </geometry>
        <material name="transp_blue2">
          <color rgba="0 0.3 0.9 0.2" />
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0.1" />
        <geometry>
          <box size="0.05 0.05 0.02" />
        </geometry>
      </collision>

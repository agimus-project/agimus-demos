    <!-- Wrap panda1 robot into a box shaped obstacle -->
    <link name="panda1_box">
      <inertial>
        <mass value="100" />
        <origin xyz="0 0 0" />
        <inertia ixx="25" ixy="0" ixz="0" iyy="25" iyz="0" izz="25" />
      </inertial>
      <collision>
        <origin xyz="0 0 0" />
        <geometry>
          <box size="0.44 0.803 0.80" />
        </geometry>
      </collision>
      <visual>
        <origin xyz="0 0 0" />
        <geometry>
          <box size="0.44 0.803 0.80" />
        </geometry>
        <material name="lightGrey">
          <color rgba="0.9 0.9 0.9 0.5" />
        </material>
      </visual>
    </link>

    <link name="robot_attachment_link" />
    <joint name="support_joint" type="fixed">
      <origin xyz="0.563 -0.1655 .76" rpy="0 0 ${pi}" />
      <parent link="support_link" />
      <child link="robot_attachment_link" />
    </joint>
    <joint name="wall_joint_1" type="fixed">
      <origin xyz="0 1.07 0" />
      <parent link="support_link" />
      <child link="wall_link_1" />
    </joint>
    <joint name="wall_joint_2" type="fixed">
      <origin xyz="1.78 0 0" />
      <parent link="support_link" />
      <child link="wall_link_2" />
    </joint>
    <joint name="wall_joint_3" type="fixed">
      <origin xyz="1.40 0.96 0" />
      <parent link="support_link" />
      <child link="wall_link_3" />
    </joint>
    <joint name="pedestal_joint" type="fixed">
      <origin xyz="1.05 0 0" />
      <parent link="support_link" />
      <child link="pedestal" />
    </joint>
    <joint name="foam_block_joint" type="fixed">
      <origin xyz="0.0 -0.08 0.75" />
      <parent link="support_link" />
      <child link="foam_block" />
    </joint>
    <!-- <joint name="obj_pedestal2_joint" type="fixed">
      <origin xyz="0 0 0.2" />
      <parent link="obj_pedestal" />
      <child link="obj_pedestal2" />
    </joint> -->
    <joint name="panda1_box_joint" type="fixed">
      <origin xyz="-0.6315 0 1.17" />
      <parent link="support_link" />
      <child link="panda1_box" />
    </joint>
  </xacro:macro>
</robot>

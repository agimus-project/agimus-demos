<?xml version="1.0" encoding="utf-8"?>
<robot name="table">

  <material name="table_white">
    <color rgba="0.75 0.75 0.7 1.0"/>
  </material>
  <material name="table_gray">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>

  <!-- Virtual root -->
  <link name="base_link"/>

  <!-- Table top -->
  <joint name="table_top_joint" type="fixed">
    <parent link="base_link"/>
    <child link="table_top_link"/>
    <origin xyz="0 0 0.7175" rpy="0 0 0"/>
  </joint>
  <link name="table_top_link">
    <visual>
      <geometry>
        <box size="0.6 0.6 0.025"/>
      </geometry>
      <material name="table_white"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.6 0.6 0.025"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
  </link>

  <!-- Leg front-left -->
  <joint name="leg_fl_joint" type="fixed">
    <parent link="base_link"/>
    <child link="leg_fl_link"/>
    <origin xyz=" 0.275  0.275 0.350" rpy="0 0 0"/>
  </joint>
  <link name="leg_fl_link">
    <visual>
      <geometry><cylinder length="0.700" radius="0.025"/></geometry>
      <material name="table_gray"/>
    </visual>
    <collision>
      <geometry><cylinder length="0.700" radius="0.025"/></geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.04" ixy="0" ixz="0" iyy="0.04" iyz="0" izz="0.0003"/>
    </inertial>
  </link>

  <!-- Leg front-right -->
  <joint name="leg_fr_joint" type="fixed">
    <parent link="base_link"/>
    <child link="leg_fr_link"/>
    <origin xyz=" 0.275 -0.275 0.350" rpy="0 0 0"/>
  </joint>
  <link name="leg_fr_link">
    <visual>
      <geometry><cylinder length="0.700" radius="0.025"/></geometry>
      <material name="table_gray"/>
    </visual>
    <collision>
      <geometry><cylinder length="0.700" radius="0.025"/></geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.04" ixy="0" ixz="0" iyy="0.04" iyz="0" izz="0.0003"/>
    </inertial>
  </link>

  <!-- Leg rear-left -->
  <joint name="leg_rl_joint" type="fixed">
    <parent link="base_link"/>
    <child link="leg_rl_link"/>
    <origin xyz="-0.275  0.275 0.350" rpy="0 0 0"/>
  </joint>
  <link name="leg_rl_link">
    <visual>
      <geometry><cylinder length="0.700" radius="0.025"/></geometry>
      <material name="table_gray"/>
    </visual>
    <collision>
      <geometry><cylinder length="0.700" radius="0.025"/></geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.04" ixy="0" ixz="0" iyy="0.04" iyz="0" izz="0.0003"/>
    </inertial>
  </link>

  <!-- Leg rear-right -->
  <joint name="leg_rr_joint" type="fixed">
    <parent link="base_link"/>
    <child link="leg_rr_link"/>
    <origin xyz="-0.275 -0.275 0.350" rpy="0 0 0"/>
  </joint>
  <link name="leg_rr_link">
    <visual>
      <geometry><cylinder length="0.700" radius="0.025"/></geometry>
      <material name="table_gray"/>
    </visual>
    <collision>
      <geometry><cylinder length="0.700" radius="0.025"/></geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.04" ixy="0" ixz="0" iyy="0.04" iyz="0" izz="0.0003"/>
    </inertial>
  </link>

</robot>

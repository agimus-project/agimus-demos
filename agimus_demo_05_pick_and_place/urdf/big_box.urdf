<robot name="big_box">
  <material name="red">
    <color rgba=".9 .1 .1 1" />
  </material>

  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.6" />
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.001" />
    </inertial>

    <!-- Bottom plate: 0.40 x 0.305 x 0.001 -->
    <visual>
      <origin xyz="0 0 0.0005" rpy="0 0 0" />
      <geometry>
        <box size="0.40 0.305 0.001" />
      </geometry>
      <material name="red" />
    </visual>
    <collision>
      <origin xyz="0 0 0.0005" rpy="0 0 0" />
      <geometry>
        <box size="0.40 0.305 0.001" />
      </geometry>
    </collision>

    <!-- Walls: thickness 0.001, height 0.093 -->
    <!-- front wall (y +) -->
    <visual>
      <origin xyz="0 0.152 0.0475" rpy="0 0 0" />
      <geometry>
        <box size="0.398 0.001 0.093" />
      </geometry>
      <material name="red" />
    </visual>
    <collision>
      <origin xyz="0 0.152 0.0475" rpy="0 0 0" />
      <geometry>
        <box size="0.398 0.001 0.093" />
      </geometry>
    </collision>

    <!-- back wall (y -) -->
    <visual>
      <origin xyz="0 -0.152 0.0475" rpy="0 0 0" />
      <geometry>
        <box size="0.398 0.001 0.093" />
      </geometry>
      <material name="red" />
    </visual>
    <collision>
      <origin xyz="0 -0.152 0.0475" rpy="0 0 0" />
      <geometry>
        <box size="0.398 0.001 0.093" />
      </geometry>
    </collision>

    <!-- right wall (x +) -->
    <visual>
      <origin xyz="0.1995 0 0.0475" rpy="0 0 0" />
      <geometry>
        <box size="0.001 0.303 0.093" />
      </geometry>
      <material name="red" />
    </visual>
    <collision>
      <origin xyz="0.1995 0 0.0475" rpy="0 0 0" />
      <geometry>
        <box size="0.001 0.303 0.093" />
      </geometry>
    </collision>

    <!-- left wall (x -) -->
    <visual>
      <origin xyz="-0.1995 0 0.0475" rpy="0 0 0" />
      <geometry>
        <box size="0.001 0.303 0.093" />
      </geometry>
      <material name="red" />
    </visual>
    <collision>
      <origin xyz="-0.1995 0 0.0475" rpy="0 0 0" />
      <geometry>
        <box size="0.001 0.303 0.093" />
      </geometry>
    </collision>

  </link>
</robot>

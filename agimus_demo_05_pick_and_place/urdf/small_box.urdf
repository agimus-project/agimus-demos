<robot name="small_box">
  <material name="blue">
    <color rgba="0.1 0.1 0.9 1"/>
  </material>
  <link name="base_link">

    <!-- Bottom panel (floor of the box) -->
    <visual>
      <origin xyz="0 0 0.0005" rpy="0 0 0"/>
      <geometry>
        <box size="0.21 0.156 0.001"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.0005" rpy="0 0 0"/>
      <geometry>
        <box size="0.21 0.156 0.001"/>
      </geometry>
    </collision>

    <!-- Front wall -->
    <visual>
      <origin xyz="0 0.0775 0.05" rpy="0 0 0"/>
      <geometry>
        <!-- <box size="0.20 0.001 0.1"/> -->
        <box size="0.5 0.001 0.1"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0.0775 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.5 0.001 0.1"/>
      </geometry>
    </collision>

    <!-- Back wall -->
    <visual>
      <origin xyz="0 -0.0775 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.5 0.001 0.1"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 -0.0775 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.5 0.001 0.1"/>
      </geometry>
    </collision>

    <!-- Right wall -->
    <visual>
      <origin xyz="0.1045 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.001 0.146 0.1"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0.1045 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.001 0.146 0.1"/>
      </geometry>
    </collision>

    <!-- Left wall -->
    <visual>
      <origin xyz="-0.1045 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.001 0.146 0.1"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="-0.1045 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.001 0.146 0.1"/>
      </geometry>
    </collision>

  </link>
  <!-- The link and joint below are required to bypass a bug in setRootJointPosition in hpp-manipulation -->
  <link name="fake_base_link"/>
  <joint name="fake_joint" type="fixed">
  <parent link="fake_base_link"/>
  <child link="base_link"/>
  </joint>
</robot>

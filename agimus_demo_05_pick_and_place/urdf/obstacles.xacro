<?xml version='1.0' encoding='utf-8'?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="obstacles">
    <xacro:include filename="$(find agimus_franka_description)/robots/common/utils.xacro" />
    <material name="red">
        <color rgba=".9 .1 .1 1" />
    </material>
    <link name="big_box_link">
        <inertial>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <mass value="0.6" />
          <inertia ixx="0.001" ixy="0.0" ixz="0.0"
                   iyy="0.001" iyz="0.0"
                   izz="0.001" />
        </inertial>

        <!-- New target outer size: 0.40 x 0.305, bottom thickness 0.001 -->
        <visual>
          <origin xyz="0 0 0.0155" rpy="0 0 0" />
          <geometry>
            <box size="0.40 0.305 0.001" />
          </geometry>
          <material name="red" />
        </visual>
        <collision>
          <origin xyz="0 0 0.0155" rpy="0 0 0" />
          <geometry>
            <box size="0.40 0.305 0.001" />
          </geometry>
        </collision>

        <!-- Walls: thickness 0.001, height 0.093 -->
        <!-- Wall center z = bottom_z + bottom_thickness/2 + wall_height/2
             = 0.0155 + 0.0005 + 0.0465 = 0.0625 -->

        <!-- +Y wall -->
        <visual>
          <origin xyz="0 0.152 0.0625" />
          <geometry>
            <box size="0.398 0.001 0.093" />
          </geometry>
          <material name="red" />
        </visual>
        <collision>
          <origin xyz="0 0.152 0.0625" />
          <geometry>
            <box size="0.398 0.001 0.093" />
          </geometry>
        </collision>

        <!-- -Y wall -->
        <visual>
          <origin xyz="0 -0.152 0.0625" />
          <geometry>
            <box size="0.398 0.001 0.093" />
          </geometry>
          <material name="red" />
        </visual>
        <collision>
          <origin xyz="0 -0.152 0.0625" />
          <geometry>
            <box size="0.398 0.001 0.093" />
          </geometry>
        </collision>

        <!-- +X wall -->
        <visual>
          <origin xyz="0.1995 0 0.0625" />
          <geometry>
            <box size="0.001 0.303 0.093" />
          </geometry>
          <material name="red" />
        </visual>
        <collision>
          <origin xyz="0.1995 0 0.0625" />
          <geometry>
            <box size="0.001 0.303 0.093" />
          </geometry>
        </collision>

        <!-- -X wall -->
        <visual>
          <origin xyz="-0.1995 0 0.0625" />
          <geometry>
            <box size="0.001 0.303 0.093" />
          </geometry>
          <material name="red" />
        </visual>
        <collision>
          <origin xyz="-0.1995 0 0.0625" />
          <geometry>
            <box size="0.001 0.303 0.093" />
          </geometry>
        </collision>
      </link>

    <joint name="box_to_obstacle" type="fixed">
        <parent link="big_box_link" />
        <child link="obstacle1" />
        <origin xyz="0.1 0 0.5" rpy="0 0 0 " />
    </joint>
    <link name="obstacle1">
        <xacro:collision_capsule xyz="0.535 0 0.43" direction="x" radius="0.1"
            length="0.3" />
    </link>
</robot>

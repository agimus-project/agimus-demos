<?xml version="1.0"?>
<!-- Naming convention: -->
<!-- the object axis that points to robot hand is: so _x, _y or _z -->
<!-- with the sign of axis, p is positive, n is negative  -->
<!-- so if it is _zp this means that robot hand is in positive direction along z-axis -->
<!-- Next is same convention for which object axis points in the tele-button direction -->

<robot name="tless_26">

    <handle name="goal_handle_up" clearance="0.03">
        <position xyz="0.0 0.0 0.0" xyzw="0.0 0.70710678118 0.0 -0.70710678118" />
        <link name="base_link" />
        <mask>1 1 1 0 1 1</mask>
    </handle>
    <handle name="goal_handle_down" clearance="0.03">
        <position xyz="0.0 0.0 0.0" xyzw="0.0 0.70710678118 0.0 0.70710678118" />
        <link name="base_link" />
        <mask>1 1 1 0 1 1</mask>
    </handle>
    <!-- <handle name="goal_handle2" clearance="0.03">
        <position xyz="0.0 0.0 0.0" xyzw="0.0 0.0 0.0 1.0"/>
        <link name="base_link"/>
        <mask>1 1 1 0 1 1</mask>
    </handle> -->
    <handle name="zn_yp1" clearance="0.075">
        <position xyz="0.005 0.0 0.0" xyzw="0.0 0.7071067811865475 0.0 0.7071067811865476" />
        <link name="base_link" />
    </handle>

    <handle name="zn_yp2" clearance="0.075">
        <position xyz="-0.03 0.0 0.0" xyzw="0.0 0.7071067811865475 0.0 0.7071067811865476" />
        <link name="base_link" />
    </handle>

    <handle name="zn_yn1" clearance="0.075">
        <position xyz="0.005 0.0 0.0" xyzw="-0.7071067811865475 0.0 0.7071067811865476 0.0" />
        <link name="base_link" />
    </handle>

    <handle name="zn_yn2" clearance="0.075">
        <position xyz="-0.03 0.0 0.0" xyzw="-0.7071067811865475 0.0 0.7071067811865476 0.0" />
        <link name="base_link" />
    </handle>

</robot>